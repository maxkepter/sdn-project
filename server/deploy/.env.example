# =============================================================================
# sdn-project Deployment .env.example
# Sao chép thành .env (KHÔNG commit file .env) và điền giá trị thật trước khi deploy.
# =============================================================================

# --- Backend config (in-cluster, set qua ConfigMap `sdn-backend-config`) ---
NODE_ENV=production
PORT=5000
UPLOAD_DIR=/data/uploads
# Khớp với Ingress rule host (default: sdn.local — xem k8s/07-ingress.yaml)
CLIENT_URL=http://sdn.local

# Rate limiting (xem server/src/config/environment.js)
RATE_LIMIT_WINDOW_MIN=15
RATE_LIMIT_MAX=500

# --- Secrets (in-cluster, set qua Secret `sdn-secrets`) ---
# Có thể thay bằng MongoDB Atlas URI khi lên production
DATABASE_URL=mongodb://mongo-0.mongo-headless.sdn.svc.cluster.local:27017/sdn_db
JWT_SECRET=please-change-this-to-a-strong-random-secret

# --- Docker images ---
IMAGE_TAG=1.0.0
REGISTRY=sdn

# --- Frontend build-time ---
# Cùng origin với Ingress để tránh CORS phức tạp.
# Khi đổi domain Ingress, cần build lại image frontend với giá trị mới.
REACT_APP_API_URL=/api/v1